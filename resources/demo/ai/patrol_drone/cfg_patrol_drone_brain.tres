[sub_resource type="Resource" id="Condition_power_core_proximity"]
script = ExtResource("12_condition_redux_field")
state_path = "gameplay.ai_demo_flags.power_core_proximity"
match_mode = "equals"
match_value_string = "true"

[sub_resource type="Resource" id="Scorer_investigate_proximity"]
script = ExtResource("10_ai_scorer_condition")
condition = SubResource("Condition_power_core_proximity")
if_true = 11.0

[sub_resource type="Resource" id="Condition_power_core_activated"]
script = ExtResource("12_condition_redux_field")
state_path = "gameplay.ai_demo_flags.power_core_activated"
match_mode = "equals"
match_value_string = "true"

[sub_resource type="Resource" id="Scorer_investigate"]
script = ExtResource("10_ai_scorer_condition")
condition = SubResource("Condition_power_core_activated")
if_true = 9.0

[sub_resource type="Resource" id="Scorer_patrol"]
script = ExtResource("11_ai_scorer_constant")
value = 1.0

[sub_resource type="Resource" id="Node_flag_power_core_proximity"]
script = ExtResource("8_bt_condition")
condition = SubResource("Condition_power_core_proximity")

[sub_resource type="Resource" id="Action_move_to_activatable"]
script = ExtResource("13_action_move_to")
target_node_path = NodePath("../../Interactions/Inter_ActivatableNode")
arrival_threshold = 1.2

[sub_resource type="Resource" id="Node_move_to_activatable"]
script = ExtResource("9_bt_action")
action = SubResource("Action_move_to_activatable")

[sub_resource type="Resource" id="Action_scan_activatable"]
script = ExtResource("14_action_scan")
