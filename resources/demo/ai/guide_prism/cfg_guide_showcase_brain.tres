[sub_resource type="Resource" id="Condition_nav_goal_reached"]
script = ExtResource("9_condition_redux_field")
state_path = "gameplay.ai_demo_flags.nav_goal_reached"
match_mode = "equals"
match_value_string = "true"

[sub_resource type="Resource" id="Scorer_celebrate"]
script = ExtResource("7_ai_scorer_condition")
condition = SubResource("Condition_nav_goal_reached")
if_true = 12.0

[sub_resource type="Resource" id="Condition_player_airborne"]
script = ExtResource("9_condition_redux_field")
state_path = "gameplay.entities.player.is_on_floor"
match_mode = "not_equals"
match_value_string = "true"

[sub_resource type="Resource" id="Scorer_encourage"]
script = ExtResource("7_ai_scorer_condition")
condition = SubResource("Condition_player_airborne")
if_true = 8.0

[sub_resource type="Resource" id="Condition_player_nearby"]
script = ExtResource("9_condition_redux_field")
state_path = "gameplay.ai_demo_flags.guide_player_nearby"
match_mode = "equals"
match_value_string = "true"

[sub_resource type="Resource" id="Scorer_show_path"]
script = ExtResource("7_ai_scorer_condition")
condition = SubResource("Condition_player_nearby")
if_true = 4.0

[sub_resource type="Resource" id="Scorer_idle"]
script = ExtResource("8_ai_scorer_constant")
value = 1.0

[sub_resource type="Resource" id="Node_flag_nav_goal_reached"]
script = ExtResource("5_bt_condition")
condition = SubResource("Condition_nav_goal_reached")

[sub_resource type="Resource" id="Action_celebrate_spin"]
script = ExtResource("12_action_animate")
animation_state = &"spin"

[sub_resource type="Resource" id="Node_celebrate_spin"]
script = ExtResource("6_bt_action")
action = SubResource("Action_celebrate_spin")

[sub_resource type="Resource" id="Action_publish_celebration"]
script = ExtResource("13_action_publish_event")
event_name = &"signpost_message"
payload = {
"message": "gameplay.signpost.default_message",
"message_duration_sec": 2.5,
"source": &"guide_prism"
}

[sub_resource type="Resource" id="Node_publish_celebration"]
script = ExtResource("6_bt_action")
action = SubResource("Action_publish_celebration")

[sub_resource type="Resource" id="Action_wait_celebration"]
script = ExtResource("11_action_wait")
duration = 3.0

[sub_resource type="Resource" id="Node_wait_celebration"]
script = ExtResource("6_bt_action")
action = SubResource("Action_wait_celebration")

[sub_resource type="Resource" id="Node_celebration_sequence"]
script = ExtResource("3_bt_sequence")
children = Array[ExtResource("4_bt_node")]([SubResource("Node_flag_nav_goal_reached"), SubResource("Node_celebrate_spin"), SubResource("Node_publish_celebration"), SubResource("Node_wait_celebration")])

