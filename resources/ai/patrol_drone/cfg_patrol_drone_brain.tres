[gd_resource type="Resource" script_class="RS_AIBrainSettings" load_steps=4 format=3]

[ext_resource type="Script" path="res://scripts/resources/ai/rs_ai_brain_settings.gd" id="1_brain"]
[ext_resource type="Resource" path="res://resources/ai/patrol_drone/cfg_goal_patrol.tres" id="2_goal_patrol"]
[ext_resource type="Resource" path="res://resources/ai/patrol_drone/cfg_goal_investigate.tres" id="3_goal_investigate"]

[resource]
script = ExtResource("1_brain")
goals = Array[Resource]([ExtResource("2_goal_patrol"), ExtResource("3_goal_investigate")])
default_goal_id = &"patrol"
evaluation_interval = 0.2
respawn_spawn_point_id = &"sp_ai_patrol_drone"
respawn_unsupported_delay_sec = 0.6
respawn_recovery_cooldown_sec = 1.0
