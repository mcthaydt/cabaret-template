[gd_resource type="Resource" script_class="RS_AIGoal" load_steps=16 format=3]

[ext_resource type="Script" path="res://scripts/resources/ai/rs_ai_goal.gd" id="1_goal"]
[ext_resource type="Script" path="res://scripts/resources/qb/conditions/rs_condition_constant.gd" id="2_condition_constant"]
[ext_resource type="Script" path="res://scripts/resources/ai/rs_ai_compound_task.gd" id="3_compound_task"]
