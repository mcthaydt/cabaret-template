[ext_resource type="Script" path="res://scripts/resources/ai/actions/rs_ai_action_wait.gd" id="6_action_wait"]

[sub_resource type="Resource" id="Condition_patrol_constant"]
script = ExtResource("2_condition_constant")
score = 0.5

[sub_resource type="Resource" id="Action_move_waypoint_a"]
script = ExtResource("5_action_move_to")
target_node_path = NodePath("../../Waypoints/WaypointA")
arrival_threshold = 0.8

[sub_resource type="Resource" id="Task_move_waypoint_a"]
