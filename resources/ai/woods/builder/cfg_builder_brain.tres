[ext_resource type="Script" path="res://scripts/resources/ai/actions/rs_ai_action_move_to_nearest.gd" id="15_action_move_to_nearest"]

[sub_resource type="Resource" id="Condition_thirst_low"]
script = ExtResource("8_condition_component_field")
component_type = &"C_NeedsComponent"
field_path = "thirst"
range_max = 0.25
invert = true

[sub_resource type="Resource" id="Scorer_thirst_high"]
script = ExtResource("6_ai_scorer_condition")
condition = SubResource("Condition_thirst_low")
if_true = 12.0

[sub_resource type="Resource" id="Condition_inventory_not_full"]
script = ExtResource("8_condition_component_field")
component_type = &"C_InventoryComponent"
field_path = "fill_ratio"
invert = true

[sub_resource type="Resource" id="Scorer_gather_wood"]
script = ExtResource("6_ai_scorer_condition")
condition = SubResource("Condition_inventory_not_full")
if_true = 3.0

[sub_resource type="Resource" id="Condition_inventory_has_items"]
script = ExtResource("8_condition_component_field")
component_type = &"C_InventoryComponent"
field_path = "fill_ratio"

[sub_resource type="Resource" id="Scorer_haul_deposit"]
script = ExtResource("6_ai_scorer_condition")
condition = SubResource("Condition_inventory_has_items")
if_true = 4.0

[sub_resource type="Resource" id="Condition_build_materials_ready"]
script = ExtResource("8_condition_component_field")
component_type = &"C_BuildSiteComponent"
field_path = "materials_ready"

[sub_resource type="Resource" id="Scorer_build_stage"]
script = ExtResource("6_ai_scorer_condition")
condition = SubResource("Condition_build_materials_ready")
if_true = 5.0

[sub_resource type="Resource" id="Scorer_wander"]
script = ExtResource("7_ai_scorer_constant")
value = 1.0

[sub_resource type="Resource" id="Action_drink"]
script = ExtResource("13_action_drink")

[sub_resource type="Resource" id="Node_drink"]
script = ExtResource("5_bt_action")
action = SubResource("Action_drink")

[sub_resource type="Resource" id="Node_drink_sequence"]
script = ExtResource("3_bt_sequence")
children = Array[ExtResource("4_bt_node")]([SubResource("Node_drink")])

[sub_resource type="Resource" id="Action_move_to_resource"]
script = ExtResource("15_action_move_to_nearest")
scan_component_type = &"C_ResourceNodeComponent"
scan_filter = &"is_available"
arrival_threshold = 1.5

[sub_resource type="Resource" id="Node_move_to_resource"]
script = ExtResource("5_bt_action")
action = SubResource("Action_move_to_resource")

[sub_resource type="Resource" id="Action_reserve_tree"]
script = ExtResource("14_action_reserve")

[sub_resource type="Resource" id="Node_reserve_tree"]
script = ExtResource("5_bt_action")
action = SubResource("Action_reserve_tree")

[sub_resource type="Resource" id="Action_harvest_wood"]
script = ExtResource("10_action_harvest")

[sub_resource type="Resource" id="Node_harvest_wood"]
script = ExtResource("5_bt_action")
action = SubResource("Action_harvest_wood")

[sub_resource type="Resource" id="Node_gather_wood_sequence"]
script = ExtResource("3_bt_sequence")
children = Array[ExtResource("4_bt_node")]([SubResource("Node_move_to_resource"), SubResource("Node_reserve_tree"), SubResource("Node_harvest_wood")])

[sub_resource type="Resource" id="Action_move_to_build_site"]
script = ExtResource("15_action_move_to_nearest")
scan_component_type = &"C_BuildSiteComponent"
arrival_threshold = 1.5

[sub_resource type="Resource" id="Node_move_to_build_site"]
script = ExtResource("5_bt_action")
action = SubResource("Action_move_to_build_site")

[sub_resource type="Resource" id="Action_haul_deposit"]
script = ExtResource("11_action_haul_deposit")

[sub_resource type="Resource" id="Node_haul_deposit"]
script = ExtResource("5_bt_action")
action = SubResource("Action_haul_deposit")

[sub_resource type="Resource" id="Node_haul_sequence"]
script = ExtResource("3_bt_sequence")
children = Array[ExtResource("4_bt_node")]([SubResource("Node_move_to_build_site"), SubResource("Node_haul_deposit")])

[sub_resource type="Resource" id="Action_build_stage"]
script = ExtResource("12_action_build_stage")

[sub_resource type="Resource" id="Node_build_stage"]
script = ExtResource("5_bt_action")
action = SubResource("Action_build_stage")

[sub_resource type="Resource" id="Node_build_sequence"]
script = ExtResource("3_bt_sequence")
children = Array[ExtResource("4_bt_node")]([SubResource("Node_move_to_build_site"), SubResource("Node_build_stage")])

[sub_resource type="Resource" id="Action_wander_builder"]
script = ExtResource("9_action_wander")
home_radius = 12.0

[sub_resource type="Resource" id="Node_wander"]
script = ExtResource("5_bt_action")
action = SubResource("Action_wander_builder")

[sub_resource type="Resource" id="Node_builder_root"]
resource_name = "builder_bt_root"
script = ExtResource("2_bt_utility_selector")
child_scorers = Array[Resource]([SubResource("Scorer_thirst_high"), SubResource("Scorer_gather_wood"), SubResource("Scorer_haul_deposit"), SubResource("Scorer_build_stage"), SubResource("Scorer_wander")])
children = Array[ExtResource("4_bt_node")]([SubResource("Node_drink_sequence"), SubResource("Node_gather_wood_sequence"), SubResource("Node_haul_sequence"), SubResource("Node_build_sequence"), SubResource("Node_wander")])

[resource]
script = ExtResource("1_brain")
root = SubResource("Node_builder_root")
evaluation_interval = 0.3