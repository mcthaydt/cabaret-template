[gd_resource type="Resource" script_class="RS_AIGoal" format=3]

[ext_resource type="Script" path="res://scripts/interfaces/i_condition.gd" id="1_condition"]
[ext_resource type="Script" path="res://scripts/resources/ai/goals/rs_ai_goal.gd" id="1_goal"]
[ext_resource type="Script" path="res://scripts/resources/qb/conditions/rs_condition_component_field.gd" id="2_condition_component_field"]
[ext_resource type="Script" path="res://scripts/resources/ai/tasks/rs_ai_primitive_task.gd" id="3_primitive_task"]
[ext_resource type="Script" path="res://scripts/resources/ai/actions/rs_ai_action_flee_from_detected.gd" id="4_action_flee_detected"]

[sub_resource type="Resource" id="Condition_detected_in_range"]
script = ExtResource("2_condition_component_field")
component_type = &"C_DetectionComponent"
field_path = "is_player_in_range"

[sub_resource type="Resource" id="Action_flee_detected"]
script = ExtResource("4_action_flee_detected")
flee_distance = 9.0
arrival_threshold = 0.6

[sub_resource type="Resource" id="Task_flee_detected"]
script = ExtResource("3_primitive_task")
action = SubResource("Action_flee_detected")
task_id = &"flee_from_detected"

[resource]
script = ExtResource("1_goal")
goal_id = &"flee"
conditions = Array[ExtResource("1_condition")]([SubResource("Condition_detected_in_range")])
root_task = SubResource("Task_flee_detected")
priority = 10
