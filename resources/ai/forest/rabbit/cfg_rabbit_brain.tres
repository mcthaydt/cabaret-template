[gd_resource type="Resource" script_class="RS_AIBrainSettings" format=3]

[ext_resource type="Script" path="res://scripts/resources/ai/brain/rs_ai_brain_settings.gd" id="1_brain"]
[ext_resource type="Script" path="res://scripts/resources/ai/goals/rs_ai_goal.gd" id="1_goal"]
[ext_resource type="Resource" path="res://resources/ai/forest/shared/cfg_goal_flee.tres" id="2_goal_flee"]
[ext_resource type="Resource" path="res://resources/ai/forest/shared/cfg_goal_graze.tres" id="3_goal_graze"]
[ext_resource type="Resource" path="res://resources/ai/forest/shared/cfg_goal_wander.tres" id="4_goal_wander"]

[resource]
script = ExtResource("1_brain")
goals = Array[ExtResource("1_goal")]([ExtResource("2_goal_flee"), ExtResource("3_goal_graze"), ExtResource("4_goal_wander")])
default_goal_id = &"wander"
evaluation_interval = 0.25
