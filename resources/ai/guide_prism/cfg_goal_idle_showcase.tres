[sub_resource type="Resource" id="Condition_not_near_player"]
script = ExtResource("2_condition_redux")
state_path = "gameplay.ai_demo_flags.guide_player_nearby"
match_mode = "not_equals"
match_value_string = "true"

[sub_resource type="Resource" id="Action_idle_wait"]
script = ExtResource("5_action_wait")
