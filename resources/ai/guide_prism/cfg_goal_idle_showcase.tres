task_id = &"idle_sequence"

[resource]
script = ExtResource("1_goal")
goal_id = &"idle"
conditions = Array[ExtResource("1_l828v")]([SubResource("Condition_not_near_player")])
root_task = SubResource("Task_idle_sequence")
priority = 1
