[gd_resource type="Resource" script_class="RS_AIGoal" format=3]

[ext_resource type="Script" path="res://scripts/resources/ai/rs_ai_goal.gd" id="1_goal"]
[ext_resource type="Script" path="res://scripts/resources/qb/conditions/rs_condition_redux_field.gd" id="2_condition_redux"]
[ext_resource type="Script" path="res://scripts/resources/ai/rs_ai_compound_task.gd" id="3_compound_task"]
[ext_resource type="Script" path="res://scripts/resources/ai/rs_ai_primitive_task.gd" id="4_primitive_task"]
[ext_resource type="Script" path="res://scripts/resources/ai/actions/rs_ai_action_move_to.gd" id="5_action_move_to"]
[ext_resource type="Script" path="res://scripts/resources/ai/actions/rs_ai_action_wait.gd" id="6_action_wait"]

[sub_resource type="Resource" id="Condition_near_player"]
script = ExtResource("2_condition_redux")
state_path = "gameplay.ai_demo_flags.guide_player_nearby"
match_mode = "equals"
match_value_string = "true"

[sub_resource type="Resource" id="Action_move_marker_a"]
script = ExtResource("5_action_move_to")
target_node_path = NodePath("../../PathMarkers/PathMarkerA")
arrival_threshold = 0.9

[sub_resource type="Resource" id="Task_move_marker_a"]
script = ExtResource("4_primitive_task")
action = SubResource("Action_move_marker_a")
task_id = &"move_marker_a"

[sub_resource type="Resource" id="Action_wait_marker_a"]
script = ExtResource("6_action_wait")

[sub_resource type="Resource" id="Task_wait_marker_a"]
script = ExtResource("4_primitive_task")
action = SubResource("Action_wait_marker_a")
task_id = &"wait_marker_a"

[sub_resource type="Resource" id="Action_move_marker_b"]
script = ExtResource("5_action_move_to")
target_node_path = NodePath("../../PathMarkers/PathMarkerB")
arrival_threshold = 0.9

[sub_resource type="Resource" id="Task_move_marker_b"]
script = ExtResource("4_primitive_task")
action = SubResource("Action_move_marker_b")
task_id = &"move_marker_b"

[sub_resource type="Resource" id="Action_wait_marker_b"]
script = ExtResource("6_action_wait")

[sub_resource type="Resource" id="Task_wait_marker_b"]
script = ExtResource("4_primitive_task")
action = SubResource("Action_wait_marker_b")
task_id = &"wait_marker_b"

[sub_resource type="Resource" id="Action_move_marker_c"]
script = ExtResource("5_action_move_to")
target_node_path = NodePath("../../PathMarkers/PathMarkerC")
arrival_threshold = 0.9

[sub_resource type="Resource" id="Task_move_marker_c"]
script = ExtResource("4_primitive_task")
action = SubResource("Action_move_marker_c")
task_id = &"move_marker_c"

[sub_resource type="Resource" id="Action_wait_marker_c"]
script = ExtResource("6_action_wait")

[sub_resource type="Resource" id="Task_wait_marker_c"]
script = ExtResource("4_primitive_task")
action = SubResource("Action_wait_marker_c")
task_id = &"wait_marker_c"

[sub_resource type="Resource" id="Action_move_marker_d"]
script = ExtResource("5_action_move_to")
target_node_path = NodePath("../../PathMarkers/PathMarkerD")
arrival_threshold = 0.9

[sub_resource type="Resource" id="Task_move_marker_d"]
script = ExtResource("4_primitive_task")
action = SubResource("Action_move_marker_d")
task_id = &"move_marker_d"

[sub_resource type="Resource" id="Action_wait_marker_d"]
script = ExtResource("6_action_wait")

[sub_resource type="Resource" id="Task_wait_marker_d"]
script = ExtResource("4_primitive_task")
action = SubResource("Action_wait_marker_d")
task_id = &"wait_marker_d"

[sub_resource type="Resource" id="Task_show_path_sequence"]
script = ExtResource("3_compound_task")
subtasks = Array[Resource]([SubResource("Task_move_marker_a"), SubResource("Task_wait_marker_a"), SubResource("Task_move_marker_b"), SubResource("Task_wait_marker_b"), SubResource("Task_move_marker_c"), SubResource("Task_wait_marker_c"), SubResource("Task_move_marker_d"), SubResource("Task_wait_marker_d")])
task_id = &"show_path_sequence"

[resource]
script = ExtResource("1_goal")
goal_id = &"show_path"
conditions = Array[Resource]([SubResource("Condition_near_player")])
root_task = SubResource("Task_show_path_sequence")
priority = 2
