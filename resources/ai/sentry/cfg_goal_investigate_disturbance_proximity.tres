[gd_resource type="Resource" script_class="RS_AIGoal" format=3]

[ext_resource type="Script" uid="uid://xhe4388ulpe1" path="res://scripts/resources/ai/rs_ai_goal.gd" id="1_goal"]
[ext_resource type="Script" uid="uid://bbw7r0gg2jdbf" path="res://scripts/resources/qb/conditions/rs_condition_redux_field.gd" id="2_condition_redux"]
[ext_resource type="Script" uid="uid://bb7kg3r8twqau" path="res://scripts/resources/ai/rs_ai_compound_task.gd" id="3_compound_task"]
[ext_resource type="Script" uid="uid://ut0hjawm2yq3" path="res://scripts/resources/ai/rs_ai_primitive_task.gd" id="4_primitive_task"]
[ext_resource type="Script" uid="uid://bqdnedsa4xgps" path="res://scripts/resources/ai/actions/rs_ai_action_move_to.gd" id="5_action_move_to"]
[ext_resource type="Script" uid="uid://c6kwruacxjm85" path="res://scripts/resources/ai/actions/rs_ai_action_scan.gd" id="6_action_scan"]
[ext_resource type="Script" path="res://scripts/resources/ai/actions/rs_ai_action_publish_event.gd" id="7_action_publish_event"]

[sub_resource type="Resource" id="Condition_proximity"]
script = ExtResource("2_condition_redux")
state_path = "gameplay.ai_demo_flags.comms_disturbance_proximity"
match_mode = "equals"
match_value_string = "true"

[sub_resource type="Resource" id="Action_move_to_noise"]
script = ExtResource("5_action_move_to")
target_node_path = NodePath("../../NoiseSources/Inter_NoiseSourceA")
arrival_threshold = 1.1

[sub_resource type="Resource" id="Action_publish_alarm"]
script = ExtResource("7_action_publish_event")
event_name = &"ai_alarm_triggered"
payload = {
"source": &"sentry"
}

[sub_resource type="Resource" id="Task_publish_alarm"]
script = ExtResource("4_primitive_task")
action = SubResource("Action_publish_alarm")
task_id = &"publish_alarm"

[sub_resource type="Resource" id="Task_move_to_noise"]
script = ExtResource("4_primitive_task")
action = SubResource("Action_move_to_noise")
task_id = &"move_to_noise"

[sub_resource type="Resource" id="Action_scan_disturbance"]
script = ExtResource("6_action_scan")
scan_duration = 4.0
rotation_speed = 1.4

[sub_resource type="Resource" id="Task_scan_disturbance"]
script = ExtResource("4_primitive_task")
action = SubResource("Action_scan_disturbance")
task_id = &"scan_disturbance"

[sub_resource type="Resource" id="Action_return_to_post"]
script = ExtResource("5_action_move_to")
target_node_path = NodePath("../../Waypoints/WaypointGuardB")
arrival_threshold = 0.9

[sub_resource type="Resource" id="Task_return_to_post"]
script = ExtResource("4_primitive_task")
action = SubResource("Action_return_to_post")
task_id = &"return_to_post"

[sub_resource type="Resource" id="Task_investigate_proximity_noise_sequence"]
script = ExtResource("3_compound_task")
subtasks = Array[Resource]([SubResource("Task_publish_alarm"), SubResource("Task_move_to_noise"), SubResource("Task_scan_disturbance"), SubResource("Task_return_to_post")])
task_id = &"investigate_proximity_noise_sequence"

[resource]
script = ExtResource("1_goal")
goal_id = &"investigate_disturbance_proximity"
conditions = Array[Resource]([SubResource("Condition_proximity")])
root_task = SubResource("Task_investigate_proximity_noise_sequence")
priority = 2
cooldown = 3.0
requires_rising_edge = true