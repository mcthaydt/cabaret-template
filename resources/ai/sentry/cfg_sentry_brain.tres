[sub_resource type="Resource" id="Condition_disturbance_proximity"]
script = ExtResource("12_condition_redux_field")
state_path = "gameplay.ai_demo_flags.comms_disturbance_proximity"
match_mode = "equals"
match_value_string = "true"

[sub_resource type="Resource" id="Scorer_disturbance_proximity"]
script = ExtResource("10_ai_scorer_condition")
condition = SubResource("Condition_disturbance_proximity")
if_true = 11.0

[sub_resource type="Resource" id="Condition_disturbance_heard"]
script = ExtResource("12_condition_redux_field")
state_path = "gameplay.ai_demo_flags.comms_disturbance_heard"
match_mode = "equals"
match_value_string = "true"

[sub_resource type="Resource" id="Scorer_disturbance_heard"]
script = ExtResource("10_ai_scorer_condition")
condition = SubResource("Condition_disturbance_heard")
if_true = 9.0

[sub_resource type="Resource" id="Scorer_guard"]
script = ExtResource("11_ai_scorer_constant")
value = 1.0

[sub_resource type="Resource" id="Node_flag_disturbance_proximity"]
script = ExtResource("8_bt_condition")
condition = SubResource("Condition_disturbance_proximity")

[sub_resource type="Resource" id="Action_publish_alarm"]
script = ExtResource("15_action_publish_event")
event_name = &"ai_alarm_triggered"
payload = {
"source": &"sentry"
}

[sub_resource type="Resource" id="Node_publish_alarm"]
script = ExtResource("9_bt_action")
action = SubResource("Action_publish_alarm")

[sub_resource type="Resource" id="Action_move_to_noise"]
script = ExtResource("13_action_move_to")
target_node_path = NodePath("../../NoiseSources/Inter_NoiseSourceA")
arrival_threshold = 1.1

[sub_resource type="Resource" id="Node_move_to_noise"]
script = ExtResource("9_bt_action")
action = SubResource("Action_move_to_noise")

[sub_resource type="Resource" id="Action_scan_disturbance"]
