"beat_id": &"intro_beat_1"
}
inject_entity_id = false

[sub_resource type="Resource" id="Resource_b4n8v"]
script = ExtResource("3_5n2ac")
event_name = &"signpost_message"
payload = {
"message": "hud.scene_director_intro_beat_1",
"message_duration_sec": 1.8
}
inject_entity_id = false

[sub_resource type="Resource" id="Resource_n2h5g"]
script = ExtResource("2_vf4lq")
