property_path = "modulate:a"
from_value = 1.0
to_value = 0.0
duration_sec = 0.3
transition_type = 0
ease_type = 0

[resource]
script = ExtResource("1_motion_set")
enter = Array[Resource]([SubResource("MotionPreset_toast_fade_in"), SubResource("MotionPreset_toast_hold"), SubResource("MotionPreset_toast_fade_out")])
