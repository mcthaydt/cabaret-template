[gd_resource type="Resource" script_class="RS_UIMotionSet" format=3]

[ext_resource type="Script" path="res://scripts/resources/ui/rs_ui_motion_set.gd" id="1_motion_set"]
[ext_resource type="Script" path="res://scripts/resources/ui/rs_ui_motion_preset.gd" id="2_motion_preset"]

[sub_resource type="Resource" id="MotionPreset_enter_fade"]
script = ExtResource("2_motion_preset")
property_path = "modulate:a"
from_value = 0.0
to_value = 1.0
duration_sec = 0.2

[sub_resource type="Resource" id="MotionPreset_enter_scale_x"]
script = ExtResource("2_motion_preset")
property_path = "scale:x"
from_value = 0.92
to_value = 1.0
duration_sec = 0.2
parallel = true

[sub_resource type="Resource" id="MotionPreset_enter_scale_y"]
script = ExtResource("2_motion_preset")
property_path = "scale:y"
from_value = 0.92
to_value = 1.0
duration_sec = 0.2
parallel = true

[sub_resource type="Resource" id="MotionPreset_exit_fade"]
script = ExtResource("2_motion_preset")
property_path = "modulate:a"
from_value = 1.0
to_value = 0.0
duration_sec = 0.16

[resource]
script = ExtResource("1_motion_set")
enter = Array[Resource]([SubResource("MotionPreset_enter_fade"), SubResource("MotionPreset_enter_scale_x"), SubResource("MotionPreset_enter_scale_y")])
exit = Array[Resource]([SubResource("MotionPreset_exit_fade")])
