[gd_resource type="Resource" script_class="RS_SceneDirective" format=3]

[ext_resource type="Script" path="res://scripts/resources/scene_director/rs_scene_directive.gd" id="1_7m0t8"]
[ext_resource type="Script" path="res://scripts/resources/scene_director/rs_beat_definition.gd" id="2_vf4lq"]
[ext_resource type="Script" path="res://scripts/resources/qb/effects/rs_effect_publish_event.gd" id="3_5n2ac"]

[sub_resource type="Resource" id="Resource_x7u2p"]
script = ExtResource("3_5n2ac")
event_name = &"scene_director_intro_beat_1"
payload = {
"beat_id": &"intro_beat_1"
}
inject_entity_id = false

[sub_resource type="Resource" id="Resource_ae8m3"]
script = ExtResource("3_5n2ac")
event_name = &"scene_director_intro_beat_2"
payload = {
"beat_id": &"intro_beat_2"
}
inject_entity_id = false

[sub_resource type="Resource" id="Resource_n2h5g"]
script = ExtResource("2_vf4lq")
beat_id = &"intro_beat_1"
description = "Publishes the initial gameplay intro event."
effects = Array[Resource]([SubResource("Resource_x7u2p")])

[sub_resource type="Resource" id="Resource_l1k9z"]
script = ExtResource("2_vf4lq")
beat_id = &"intro_beat_2"
description = "Publishes a follow-up intro event after a short delay."
effects = Array[Resource]([SubResource("Resource_ae8m3")])
wait_mode = 1
duration = 0.05

[resource]
script = ExtResource("1_7m0t8")
directive_id = &"gameplay_base_intro"
description = "Default introductory directive for gameplay_base."
target_scene_id = &"gameplay_base"
selection_conditions = Array[Resource]([])
priority = 0
beats = Array[Resource]([SubResource("Resource_n2h5g"), SubResource("Resource_l1k9z")])
