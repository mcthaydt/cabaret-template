[gd_resource type="Resource" script_class="RS_BuildSiteSettings" format=3]

[ext_resource type="Script" path="res://scripts/resources/ai/world/rs_build_site_settings.gd" id="1_0"]
[ext_resource type="Script" path="res://scripts/resources/ai/world/rs_build_stage.gd" id="2_stage"]

[sub_resource type="Resource" id="Stage_foundation"]
script = ExtResource("2_stage")
stage_id = &"foundation"
required_materials = { &"wood": 2, &"stone": 1 }
build_seconds = 3.0
visual_node_path = NodePath("Foundation")

[sub_resource type="Resource" id="Stage_frame"]
script = ExtResource("2_stage")
stage_id = &"frame"
required_materials = { &"wood": 3 }
build_seconds = 4.0
visual_node_path = NodePath("Frame")

[sub_resource type="Resource" id="Stage_walls"]
script = ExtResource("2_stage")
stage_id = &"walls"
required_materials = { &"wood": 2, &"stone": 1 }
build_seconds = 5.0
visual_node_path = NodePath("Walls")

[sub_resource type="Resource" id="Stage_roof"]
script = ExtResource("2_stage")
stage_id = &"roof"
required_materials = { &"wood": 2 }
build_seconds = 3.0
visual_node_path = NodePath("Roof")

[resource]
script = ExtResource("1_0")
stages = [SubResource("Stage_foundation"), SubResource("Stage_frame"), SubResource("Stage_walls"), SubResource("Stage_roof")]