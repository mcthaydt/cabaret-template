; NOTE: This .tscn was created directly (no builder script exists yet for tabbed settings panels).
; Migrate to a builder script once U_EditorPrefabBuilder or a new tab-panel builder supports this structure.
[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://scripts/core/ui/settings/ui_settings_panel.gd" id="1_script"]

[node name="UI_SettingsPanel" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("1_script")

[node name="OverlayBackground" type="ColorRect" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
color = Color(0, 0, 0, 0.7)
mouse_filter = 2

[node name="CenterContainer" type="CenterContainer" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2

[node name="Panel" type="PanelContainer" parent="CenterContainer"]
layout_mode = 2
custom_minimum_size = Vector2(860, 620)

[node name="VBox" type="VBoxContainer" parent="CenterContainer/Panel"]
layout_mode = 2

[node name="TabBar" type="HBoxContainer" parent="CenterContainer/Panel/VBox"]
layout_mode = 2

[node name="HSeparator" type="HSeparator" parent="CenterContainer/Panel/VBox"]
layout_mode = 2

[node name="ContentContainer" type="VBoxContainer" parent="CenterContainer/Panel/VBox"]
layout_mode = 2
size_flags_vertical = 3